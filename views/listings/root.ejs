<main
  style="
    background-color: #ffffff;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  "
>
  <div
    style="
      max-width: 600px;
      width: 100%;
      text-align: center;
      font-family: &quot;Segoe UI&quot;, Tahoma, Geneva, Verdana, sans-serif;
    "
  >
    <h1 style="color: #222; font-size: 2.5rem; margin-bottom: 10px">
      Welcome to Travel Buddy
    </h1>
    <p style="color: #666; margin-bottom: 40px; font-size: 1.1rem">
      Discover amazing places and share your own adventures.
    </p>

    <!-- Button Container -->
    <div
      style="
        display: flex;
        flex-direction: column;
        gap: 15px;
        align-items: center;
      "
    >
      <!-- Explore Button (Primary) -->
      <a
        href="/listings"
        style="
          background-color: #fe424d;
          color: white;
          text-decoration: none;
          padding: 14px 0;
          width: 100%;
          max-width: 350px;
          border-radius: 8px;
          font-weight: 600;
          font-size: 1.1rem;
          transition: opacity 0.2s;
          display: block;
        "
      >
        Explore All Listings
      </a>

      <!-- Auth Buttons Row -->
      <div
        style="
          display: flex;
          gap: 15px;
          width: 100%;
          max-width: 350px;
          justify-content: center;
        "
      >
        <a
          href="/login"
          style="
            flex: 1;
            border: 2px solid #fe424d;
            color: #fe424d;
            text-decoration: none;
            padding: 12px 0;
            border-radius: 8px;
            font-weight: 600;
            text-align: center;
          "
        >
          Login
        </a>

        <a
          href="/signup"
          style="
            flex: 1;
            border: 2px solid #fe424d;
            color: #fe424d;
            text-decoration: none;
            padding: 12px 0;
            border-radius: 8px;
            font-weight: 600;
            text-align: center;
          "
        >
          Sign Up
        </a>
      </div>
    </div>
  </div>
</main>

<!-- Include your existing Footer here -->
