<% layout("/layouts/biolerplate") %>
<script>
    const mapToken = "<%= process.env.MAPS_API_KEY %>";
    const listingData = <%- JSON.stringify(listings) %>; 
</script>

<div class="row mt-4 px-3 px-md-0">
  <div class="col-12 col-md-10 offset-md-1 col-lg-8 offset-lg-2">
    <h2 class="mb-3"><b><%= listings.title %></b></h2>
  </div>

  <div class="col-12 col-md-10 offset-md-1 col-lg-8 offset-lg-2 mb-4">
    <img src="<%= listings.image.url %>" class="show-img" alt="listing_image" />
  </div>

  <div class="col-12 col-md-10 offset-md-1 col-lg-8 offset-lg-2">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
      <h4 class="m-0"><b>Hosted by <i><%= listings.owner ? listings.owner.username : "Unknown" %></i></b></h4>
      <h5 class="mb-0 text-muted">&#8377;<%= listings.price.toLocaleString("en-IN") %> <small>/ night</small></h5>
    </div>
    <hr/>
    <p class="mb-4" style="line-height: 1.6; font-size: 1.1rem; color: #444;">
      <%= listings.description %>
    </p>

    <div class="mb-4 bg-light p-3 rounded-4 shadow-sm">
      <p class="mb-2 text-dark fs-5"><i class="fa-solid fa-location-dot me-3 text-danger"></i><%= listings.location %></p>
      <p class="mb-0 text-dark fs-5"><i class="fa-solid fa-globe me-3 text-primary"></i><%= listings.country %></p>
    </div>

    <% if(curruser && curruser._id.equals(listings.owner._id)){%>
      <div class="d-flex gap-3 mb-4">
        <a href="/listings/<%= listings._id %>/edit" class="btn btn-dark edit-btn px-4 py-2">Edit Listing</a>
        <form method="POST" action="/listings/<%= listings._id %>?_method=DELETE" class="m-0">
          <button class="btn btn-outline-danger px-4 py-2">Delete</button>
        </form>
      </div>
    <% } %>
  </div>
</div>

<hr class="col-12 col-md-10 offset-md-1 col-lg-8 offset-lg-2 my-4" />

<div class="row px-3 px-md-0">
  <div class="col-12 col-md-10 offset-md-1 col-lg-8 offset-lg-2 mb-3">
    <% if(curruser){%>
      <h4 class="mb-4">Leave a Review</h4>
      <form action="/listings/<%=listings.id%>/reviews" method="POST" novalidate class="needs-validation bg-light p-4 rounded-4 shadow-sm mb-4">
        <div class="mb-3">
          <fieldset class="starability-slot">
            <legend class="fs-6">Rating:</legend>
            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
            <label for="first-rate1" title="Terrible">1 star</label>
            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
            <label for="first-rate2" title="Not good">2 stars</label>
            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
            <label for="first-rate3" title="Average">3 stars</label>
            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
            <label for="first-rate4" title="Very good">4 stars</label>
            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
            <label for="first-rate5" title="Amazing">5 stars</label>
          </fieldset>
        </div>
        
        <div class="mb-3">
          <label for="comment" class="form-label">Share your experience</label>
          <textarea name="review[comment]" id="comment" cols="30" rows="4" class="form-control rounded-3" required placeholder="What did you love about this place?"></textarea>
          <div class="invalid-feedback">Please add a comment to submit your review.</div>
        </div>
        <button class="btn btn-dark px-4">Submit Review</button>
      </form>
      <hr class="my-5" />
    <% } else { %>
      <div class="bg-light p-4 rounded-4 shadow-sm mb-4 text-center">
        <h5 class="mb-3">Want to leave a review?</h5>
        <a href="/login" class="btn btn-outline-dark px-4 py-2">Login to Add Reviews</a>
      </div>
      <hr class="my-5" />
    <% } %>

    <% if(listings.reviews.length > 0 ) { %>
      <h4 class="mb-4">All Reviews (<%= listings.reviews.length %>)</h4>
      <div class="row">
        <% for(review of listings.reviews) { %>
          <div class="col-12 col-md-6 mb-4">
            <div class="card h-100 border-0 shadow-sm p-3 rounded-4">
              <div class="card-body p-2">
                <div class="d-flex align-items-center justify-content-between mb-2">
                  <h6 class="card-title mb-0"><b>@<%=review.author.username%></b></h6>
                  <p class="starability-result mb-0" data-rating="<%=review.rating%>" style="transform: scale(0.65); transform-origin: right;"></p>
                </div>
                <p class="card-text text-muted mb-3" style="font-size: 0.95rem; line-height: 1.5;"><%=review.comment%></p>
                <% if(curruser && review.author.equals(curruser._id)) { %>
                  <form method="POST" action="/listings/<%=listings._id%>/reviews/<%=review._id%>?_method=DELETE" class="m-0">
                    <button class="btn btn-sm btn-outline-danger">Remove</button>
                  </form>
                <% } %>
              </div>
            </div>
          </div>
        <% } %>
      </div>
    <% } else { %>
      <h5 class="text-muted mb-4">No reviews yet. Be the first to leave one!</h5>
    <% } %>
  </div>
</div>

<hr class="col-12 col-md-10 offset-md-1 col-lg-8 offset-lg-2 my-4" />

<div class="row px-3 px-md-0 pb-5">
  <div class="col-12 col-md-10 offset-md-1 col-lg-8 offset-lg-2 mb-3">
    <h3 class="mb-4">Where You'll Be</h3>
    <div id="map" class="shadow-sm" style="height: 450px; width: 100%; border-radius: 15px;"></div>
  </div>
</div>

<script src="/js/map.js?v=1"></script>